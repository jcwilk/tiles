#!/usr/bin/env bash
# Server status and management CLI for Tiles (frontend, worker)
# Check reachability of local/remote endpoints; start, stop, restart dev servers.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# When run via ./srv symlink, SCRIPT_DIR is project root; when run as scripts/srv, SCRIPT_DIR is scripts/
if [[ -d "$SCRIPT_DIR/worker" ]]; then
  ROOT_DIR="$SCRIPT_DIR"
else
  ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
fi

# Local dev URLs (configurable via env)
VITE_DEV_URL="${VITE_DEV_URL:-http://localhost:5173}"
WORKER_DEV_URL="${WORKER_DEV_URL:-http://localhost:8787}"

# Remote/production URLs (configurable via env)
SRV_REMOTE_FRONTEND_URL="${SRV_REMOTE_FRONTEND_URL:-}"
SRV_REMOTE_WORKER_URL="${SRV_REMOTE_WORKER_URL:-${VITE_API_URL:-}}"

# PID file for dev processes
PIDFILE="$ROOT_DIR/.srv-dev.pid"

usage_help() {
  cat <<'EOF'
Usage: ./srv <command> [options]

Commands:
  status       Check reachability of local or remote endpoints (default: local)
  start        Start frontend and worker in background (npm run dev)
  stop         Stop dev processes started by ./srv start
  restart      Stop then start dev processes
  help         Show this help

Examples:
  ./srv status           # local: frontend (5173), worker (8787)
  ./srv status local     # same as above
  ./srv status remote    # production endpoints (set SRV_* env vars)
  ./srv start            # bring up dev servers
  ./srv stop             # terminate dev servers
  ./srv restart          # stop then start

Environment (local):
  VITE_DEV_URL    Frontend URL (default: http://localhost:5173)
  WORKER_DEV_URL  Worker URL (default: http://localhost:8787)

Environment (remote):
  SRV_REMOTE_FRONTEND_URL  Production frontend URL (e.g. https://owner.github.io/tiles/)
  SRV_REMOTE_WORKER_URL    Production worker URL (or VITE_API_URL)
EOF
}

status_help() {
  cat <<'EOF'
Usage: ./srv status [local|remote]

  local   Check local dev servers: frontend (Vite :5173), worker (Wrangler :8787)
  remote  Check production endpoints (GitHub Pages, Cloudflare Worker)

  Default is local if no argument given.

  Exit 0 only if all endpoints are reachable.
EOF
}

# Check reachability of a URL. Returns 0 if OK, 1 if unreachable.
check_url() {
  local url="$1"
  local label="${2:-$url}"
  if curl -sSf --connect-timeout 5 --max-time 10 "$url" -o /dev/null 2>/dev/null; then
    echo "  $label: OK"
    return 0
  else
    echo "  $label: FAIL"
    return 1
  fi
}

cmd_status_local() {
  echo "=== Local status ==="
  local frontend_ok=0 worker_ok=0
  check_url "$VITE_DEV_URL/" "frontend ($VITE_DEV_URL)" || frontend_ok=1
  check_url "$WORKER_DEV_URL/health" "worker ($WORKER_DEV_URL)" || worker_ok=1
  [[ $frontend_ok -eq 0 && $worker_ok -eq 0 ]]
}

cmd_status_remote() {
  if [[ -z "$SRV_REMOTE_FRONTEND_URL" && -z "$SRV_REMOTE_WORKER_URL" ]]; then
    echo "Error: set SRV_REMOTE_FRONTEND_URL and/or SRV_REMOTE_WORKER_URL for remote status" >&2
    echo "Example: SRV_REMOTE_FRONTEND_URL=https://owner.github.io/tiles/ SRV_REMOTE_WORKER_URL=https://tiles-worker.workers.dev ./srv status remote" >&2
    exit 1
  fi
  echo "=== Remote status ==="
  local frontend_ok=0 worker_ok=0
  if [[ -n "$SRV_REMOTE_FRONTEND_URL" ]]; then
    local frontend_url="$SRV_REMOTE_FRONTEND_URL"
    [[ "$frontend_url" != *"/" ]] && frontend_url="$frontend_url/"
    check_url "$frontend_url" "frontend ($SRV_REMOTE_FRONTEND_URL)" || frontend_ok=1
  else
    echo "  frontend: (not configured)"
  fi
  if [[ -n "$SRV_REMOTE_WORKER_URL" ]]; then
    check_url "$SRV_REMOTE_WORKER_URL/health" "worker ($SRV_REMOTE_WORKER_URL)" || worker_ok=1
  else
    echo "  worker: (not configured)"
  fi
  # Exit 0 only if all configured endpoints are OK
  [[ $frontend_ok -eq 0 && $worker_ok -eq 0 ]]
}

cmd_status() {
  local target="${1:-local}"
  case "$target" in
    local)  cmd_status_local ;;
    remote) cmd_status_remote ;;
    help|--help|-h) status_help; exit 0 ;;
    *)
      echo "Unknown: status $target" >&2
      status_help >&2
      exit 1
      ;;
  esac
}

cmd_start() {
  if [[ -f "$PIDFILE" ]]; then
    echo "Dev servers may already be running (pidfile exists). Run './srv stop' first." >&2
    exit 1
  fi
  echo "Starting frontend and worker..."
  cd "$ROOT_DIR"
  npm run dev &
  echo $! > "$PIDFILE"
  # Wait a moment for processes to spawn (concurrently forks)
  sleep 3
  echo "Started. PID file: $PIDFILE"
  echo "Run './srv status' to verify."
}

cmd_stop() {
  if [[ ! -f "$PIDFILE" ]]; then
    echo "No pidfile found. Dev servers may not have been started by ./srv." >&2
    exit 1
  fi
  local pid
  pid=$(cat "$PIDFILE")
  rm -f "$PIDFILE"
  if ! kill -0 "$pid" 2>/dev/null; then
    echo "Process $pid not running. Stopped."
    return 0
  fi
  # Kill process and descendants (npm run dev -> concurrently -> vite, wrangler)
  pkill -P "$pid" 2>/dev/null || true
  kill -TERM "$pid" 2>/dev/null || true
  sleep 2
  kill -KILL "$pid" 2>/dev/null || true
  pkill -P "$pid" 2>/dev/null || true
  echo "Stopped dev servers."
}

cmd_restart() {
  if [[ -f "$PIDFILE" ]]; then
    cmd_stop
  fi
  cmd_start
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    status)  cmd_status "${1:-local}" ;;
    start)  cmd_start ;;
    stop)   cmd_stop ;;
    restart) cmd_restart ;;
    help|--help|-h) usage_help ;;
    *)
      echo "Unknown command: $cmd" >&2
      usage_help >&2
      exit 1
      ;;
  esac
}

main "$@"
