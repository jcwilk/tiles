{
  "name": "tiles",
  "private": true,
  "workspaces": [
    "frontend",
    "worker",
    "scripts"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,worker \"npm run dev -w frontend\" \"npm run dev -w worker\"",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "tsx": "^4.21.0"
  },
  "engines": {
    "node": ">=18"
  }
}
