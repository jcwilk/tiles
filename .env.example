# Frontend (Vite) — used at build time
# Local dev: Worker runs at http://localhost:8787
# Production: Your deployed Cloudflare Worker URL
VITE_API_URL=http://localhost:8787

# GitHub Pages base path (e.g. "/" for custom domain, "/tiles/" for user pages)
# Leave unset for local dev (Vite uses "/")
# VITE_BASE_URL=/
