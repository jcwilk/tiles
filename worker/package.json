{
  "name": "@tiles/worker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --remote",
    "deploy": "wrangler deploy",
    "test": "vitest run --exclude '**/prompt-eval.test.ts'",
    "test:watch": "vitest --exclude '**/prompt-eval.test.ts'",
    "test:eval": "PROMPT_EVAL=1 vitest run src/prompt-eval.test.ts",
    "test:eval:record": "PROMPT_EVAL_RECORD=1 PROMPT_EVAL=1 vitest run src/prompt-eval.test.ts",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.6",
    "wrangler": "^4.68.0",
    "@types/node": "^22.10.0"
  }
}
